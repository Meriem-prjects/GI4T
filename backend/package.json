{
  "name": "just-click-feelinx-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --use-system-ca --env-file=.env ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "build": "tsc && prisma generate",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "seed:chatbot": "node --use-system-ca ./node_modules/tsx/dist/cli.mjs prisma/seed-chatbot-knowledge.ts",
    "seed:chatbot:partie1": "node --use-system-ca ./node_modules/tsx/dist/cli.mjs prisma/seed-chatbot-knowledge-partie1.ts",
    "translate:chatbot": "node --use-system-ca --env-file=.env ./node_modules/tsx/dist/cli.mjs prisma/translate-chatbot-knowledge.ts",
    "restructure:chatbot": "node --use-system-ca ./node_modules/tsx/dist/cli.mjs prisma/restructure-chatbot-bilingual.ts",
    "seed:faq": "node --use-system-ca ./node_modules/tsx/dist/cli.mjs prisma/seed-faq-from-chatbot.ts"
  },
  "dependencies": {
    "@google-cloud/vision": "^4.3.2",
    "@mistralai/mistralai": "^2.2.1",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "mime-types": "^2.1.35",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.5",
    "pdf-to-png-converter": "^4.0.0",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "turndown": "^7.2.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mime-types": "^2.1.4",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.11.10",
    "@types/turndown": "^5.0.6",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
