# Server
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,http://localhost:8081

# Database
DATABASE_URL=postgresql://justclick:justclick_dev@localhost:5432/justclick?schema=public

# Auth
JWT_SECRET=replace-with-a-long-random-string-at-least-64-chars
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Storage
STORAGE_DIR=./storage
STORAGE_PUBLIC_URL=http://localhost:4000/api/storage
MAX_FILE_SIZE_MB=100

# External APIs
OPENAI_API_KEY=
GOOGLE_VISION_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
PDFREST_API_KEY=
PDFREST_API_URL=https://api.pdfrest.com
DEEPL_API_KEY=

# Initial admin (only used by seed.ts)
SEED_ADMIN_EMAIL=admin@justclic.tn
SEED_ADMIN_PASSWORD=changeme-immediately
